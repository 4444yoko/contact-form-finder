{
  "manifest_version": 3,
  "name": "Contact Form Finder",
  "version": "1.0.0",
  "description": "問い合わせフォームへのリンク検出と定型文テンプレートでの下書き入力を補助します。送信は手動で行います",
  "permissions": ["activeTab", "scripting", "storage"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "問い合わせフォームを探す"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
